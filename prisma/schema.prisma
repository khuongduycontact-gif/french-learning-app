generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Level {
  A1
  A2
  B1
  B2
  C1
}

enum EnrollmentStatus {
  PENDING_PAYMENT     // vừa đăng ký, đang chờ học viên thanh toán
  AWAITING_CONFIRMATION // học viên đã bấm "Tôi đã thanh toán", chờ admin xác nhận
  CONFIRMED            // admin đã xác nhận, khoá học được mở
}

enum NotificationType {
  PAYMENT_SUBMITTED    // gửi cho admin: học viên báo đã thanh toán
  ENROLLMENT_CONFIRMED // gửi cho học viên: admin đã xác nhận mở khoá học
  PAYMENT_REJECTED     // gửi cho học viên: admin từ chối xác nhận thanh toán
  SUBMISSION_RECEIVED  // gửi cho admin: học viên vừa nộp bài tập
  SUBMISSION_GRADED    // gửi cho học viên: admin đã chữa xong bài tập
}

enum SubmissionStatus {
  SUBMITTED // học viên đã nộp, đang chờ admin chữa
  GRADED    // admin đã chữa và gửi lại bài cho học viên
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          Role           @default(USER)
  accounts      Account[]
  sessions      Session[]
  enrollments   Enrollment[]
  notifications Notification[]
  submissions   Submission[]     @relation("SubmissionsByStudent")
  gradedSubmissions Submission[] @relation("SubmissionsGradedByAdmin")
  submissionDeadlines SubmissionDeadline[]
  createdAt     DateTime       @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String       @db.Text
  level       Level        @default(A1)
  price       Int          @default(0)
  duration    Float        @default(0) // số giờ học/buổi học, cho phép lẻ (VD: 1.5 = 1 giờ 30 phút)
  sessions    Int          @default(0) // số buổi học (không còn nhập ở form quản trị, giữ lại cho dữ liệu cũ)
  lessons     Int          @default(0) // số bài giảng
  videoUrl    String?      @db.Text // ảnh hoặc video giới thiệu, lưu trên Cloudinary
  published   Boolean      @default(true)
  enrollments Enrollment[]
  materials   CourseMaterial[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CourseMaterial {
  id          String   @id @default(cuid())
  courseId    String
  name        String
  description String?  @db.Text
  files       Json     // Danh sách tệp đính kèm: [{ url, type, name }]
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
  deadlines   SubmissionDeadline[]

  @@index([courseId])
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(PENDING_PAYMENT)
  paidAmount  Int              @default(0)
  paymentNote String?          // nội dung chuyển khoản để đối chiếu (VietQR addInfo)
  confirmedAt DateTime?        // thời điểm admin xác nhận mở khoá
  createdAt   DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// Bài tập học viên nộp cho một tài liệu bài tập (CourseMaterial) cụ thể,
// thuộc một khoá học cụ thể -> admin luôn biết chính xác cần chữa bài nào,
// của khoá học nào (mỗi học viên chỉ có 1 bản nộp cho mỗi tài liệu, nộp lại
// sẽ ghi đè và chuyển về trạng thái chờ chữa).
model Submission {
  id          String           @id @default(cuid())
  courseId    String
  materialId  String
  userId      String
  files       Json             // Tệp học viên nộp: [{ url, name, type }]
  note        String?          @db.Text // Ghi chú của học viên khi nộp bài
  status      SubmissionStatus @default(SUBMITTED)
  gradedFiles Json?            // Tệp admin đã chữa gửi lại: [{ url, name, type }]
  gradedNote  String?          @db.Text // Nhận xét của admin khi chữa bài
  gradedById  String?          // Admin nào đã chữa
  gradedAt    DateTime?
  submittedAt DateTime         @default(now()) // Lần nộp (hoặc nộp lại) gần nhất
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  material CourseMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user     User           @relation("SubmissionsByStudent", fields: [userId], references: [id], onDelete: Cascade)
  gradedBy User?          @relation("SubmissionsGradedByAdmin", fields: [gradedById], references: [id], onDelete: SetNull)

  @@unique([userId, materialId])
  @@index([courseId])
  @@index([materialId])
  @@index([userId])
  @@index([gradedById])
}

// Đếm giờ nộp bài: được tạo ra ngay khi học viên tải/xem tài liệu bài tập
// (CourseMaterial, nhóm "exercise") lần đầu tiên. Từ thời điểm startedAt,
// học viên có đúng `hours` giờ (mặc định 48) để nộp bài; quá hạn thì tính
// năng nộp bài cho tài liệu đó bị khoá cho đến khi admin mở khoá lại (đặt
// lại startedAt = thời điểm hiện tại).
model SubmissionDeadline {
  id         String   @id @default(cuid())
  materialId String
  userId     String
  startedAt  DateTime @default(now()) // mốc bắt đầu đếm giờ (tải lần đầu, hoặc admin đặt lại)
  hours      Int      @default(48) // số giờ được phép nộp bài kể từ startedAt
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  material CourseMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@index([materialId])
  @@index([userId])
}

model Achievement {
  id           String   @id @default(cuid())
  level        Level // Trình độ đạt được
  studentName  String // Tên học viên
  evidenceUrl  String   @db.Text // Ảnh minh chứng (Cloudinary)
  thankYouUrls Json // Danh sách ảnh lời cảm ơn của học viên (Cloudinary): ["url1", "url2", ...]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([level])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           // người nhận thông báo
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
